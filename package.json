{
  "name": "improved-parakeet",
  "version": "0.0.1",
  "description": "API for inventory system",
  "author": "Cesar Javier Ortiz Montero",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "dev:tsx": "tsx watch src/main.ts",
    "debug": "nest start --debug --watch",
    "debug:tsx": "tsx --inspect-brk src/main.ts",
    "prod": "node dist/main",
    "start:prod": "bun run db:migrate:deploy && bun run prod",
    "health:check": "curl -f http://localhost:${PORT:-3000}/health || exit 1",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false --forceExit --testPathIgnorePatterns='integration\\.spec' --testPathIgnorePatterns='test/acceptance' --testPathIgnorePatterns='test/performance' --testPathIgnorePatterns='test/security'",
    "test:integration": "jest --ci --forceExit --testPathPattern='(integration\\.spec|acceptance/|performance/|security/)'",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r tsx/cjs node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:demo": "prisma db seed -- --demo",
    "db:reset": "prisma migrate reset",
    "db:status": "prisma migrate status",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "setup:dev": "./scripts/dev-setup.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@sentry/node": "^10.40.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "8.19.0",
    "prisma": "^7.4.1",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.3",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@nestjs/typeorm": "^11.0.0",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.13",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-filename-rules": "^1.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "prisma": {
    "seed": "tsx src/infrastructure/database/prisma/seed.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "bun run lint",
      "bun run format"
    ],
    "*.{json,md,yml,yaml}": [
      "bun run format"
    ]
  }
}
