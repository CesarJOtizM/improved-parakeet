// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Base entities for all domains
model BaseEntity {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  orgId     String // Multi-tenant organization ID

  @@map("base_entities")
}

// Organizations (Multi-tenant)
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  isActive  Boolean  @default(true)
  settings  Json?    @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users              User[]
  products           Product[]
  warehouses         Warehouse[]
  categories         Category[]
  companies          Company[]
  alertConfiguration AlertConfiguration?

  @@map("organizations")
}

// Users
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  username            String    @unique
  firstName           String
  lastName            String
  passwordHash        String
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  phone               String?
  timezone            String?   @default("UTC")
  language            String?   @default("en")
  jobTitle            String?
  department          String?
  mustChangePassword  Boolean   @default(false)
  orgId               String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id])
  userRoles    UserRole[]
  sessions     Session[]

  @@index([orgId])
  @@index([orgId, isActive])
  @@map("users")
}

// Roles
model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false)
  orgId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([name, orgId])
  @@index([isSystem])
  @@index([orgId])
  @@index([orgId, isActive])
  @@map("roles")
}

// User-Role assignments
model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  orgId  String

  // Relations
  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId, orgId])
  @@map("user_roles")
}

// Permissions
model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  module      String
  action      String

  // Relations
  rolePermissions RolePermission[]

  @@map("permissions")
}

// Role-Permission assignments
model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  // Relations
  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// Sessions
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isActive  Boolean  @default(true)
  ipAddress String?
  userAgent String?
  orgId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, orgId])
  @@index([token])
  @@index([expiresAt])
  @@index([isActive])
  @@map("sessions")
}

// OTP (One-Time Password) for password reset and account activation
model Otp {
  id          String   @id @default(cuid())
  email       String
  code        String
  type        String // PASSWORD_RESET, ACCOUNT_ACTIVATION, TWO_FACTOR
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  ipAddress   String?
  userAgent   String?
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Indexes for performance
  @@index([email, type, orgId])
  @@index([expiresAt])
  @@index([isUsed])
  @@index([orgId])
  @@map("otp")
}

// Products
model Product {
  id          String   @id @default(cuid())
  sku         String
  name        String
  description String?
  unit        String
  barcode     String?
  brand       String?
  model       String?
  price       Decimal? @db.Decimal(10, 2)
  currency    String?  @default("COP")
  costMethod        String    @default("AVG") // AVG, FIFO
  isActive          Boolean   @default(true)
  statusChangedBy   String?
  statusChangedAt   DateTime?
  companyId         String?
  orgId             String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization       Organization   @relation(fields: [orgId], references: [id])
  company            Company?       @relation(fields: [companyId], references: [id])
  categories         Category[]     @relation("ProductCategories")
  movements          MovementLine[]
  transfers          TransferLine[]
  stock              Stock[]
  reorderRules       ReorderRule[]
  saleLines          SaleLine[]
  returnLines        ReturnLine[]
  swapsAsOriginal    SaleLineSwap[] @relation("SwapOriginalProduct")
  swapsAsReplacement SaleLineSwap[] @relation("SwapReplacementProduct")
  skuMappings        IntegrationSkuMapping[]

  @@unique([sku, orgId])
  @@index([orgId])
  @@index([orgId, isActive])
  @@index([orgId, companyId])
  @@map("products")
}

// Warehouses
model Warehouse {
  id          String   @id @default(cuid())
  code        String
  name        String
  description String?
  address     String?
  isActive          Boolean   @default(true)
  statusChangedBy   String?
  statusChangedAt   DateTime?
  orgId             String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  organization  Organization  @relation(fields: [orgId], references: [id])
  locations     Location[]
  stock         Stock[]
  reorderRules  ReorderRule[]
  movements     Movement[]
  fromTransfers Transfer[]    @relation("FromTransfers")
  toTransfers   Transfer[]    @relation("ToTransfers")
  sales         Sale[]
  returns       Return[]
  integrations  IntegrationConnection[]

  @@unique([code, orgId])
  @@index([orgId])
  @@index([orgId, isActive])
  @@map("warehouses")
}

// Locations (sub-divisions within warehouses: aisles, shelves, bins, etc.)
model Location {
  id          String   @id @default(cuid())
  code        String
  name        String
  description String?
  type        String   @default("BIN") // ZONE, AISLE, RACK, SHELF, BIN
  warehouseId String
  parentId    String? // For hierarchical locations
  isActive    Boolean  @default(true)
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  parent        Location?      @relation("LocationHierarchy", fields: [parentId], references: [id])
  children      Location[]     @relation("LocationHierarchy")
  stock         Stock[]
  movementLines MovementLine[]
  saleLines     SaleLine[]
  returnLines   ReturnLine[]

  @@unique([code, warehouseId, orgId])
  @@index([warehouseId, orgId])
  @@index([parentId])
  @@index([orgId, isActive])
  @@map("locations")
}

// Stock
model Stock {
  id          String  @id @default(cuid())
  productId   String
  warehouseId String
  locationId  String? // Optional - for MVP warehouse is the location
  quantity    Int     @default(0)
  unitCost    Decimal @db.Decimal(10, 2)
  orgId       String

  // Relations
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  location  Location? @relation(fields: [locationId], references: [id])

  @@unique([productId, warehouseId, locationId, orgId])
  @@index([orgId, warehouseId])
  @@index([orgId, productId])
  @@index([locationId])
  @@map("stock")
}

// Reorder Rules
model ReorderRule {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  minQty      Decimal  @db.Decimal(10, 6)
  maxQty      Decimal  @db.Decimal(10, 6)
  safetyQty   Decimal  @db.Decimal(10, 6)
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId, orgId])
  @@index([productId, orgId])
  @@index([warehouseId, orgId])
  @@map("reorder_rules")
}

// Movements
model Movement {
  id          String    @id @default(cuid())
  type        String // IN, OUT, ADJUST_IN, ADJUST_OUT, TRANSFER_IN, TRANSFER_OUT
  status      String    @default("DRAFT") // DRAFT, POSTED, VOID, RETURNED
  warehouseId String
  contactId   String?
  reference   String?
  reason      String?
  notes       String?
  postedAt    DateTime?
  postedBy    String?
  returnedAt  DateTime?
  returnedBy  String?
  createdBy   String
  orgId       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  contact         Contact?       @relation(fields: [contactId], references: [id])
  lines           MovementLine[]
  sale            Sale?
  sourceReturns   Return[]       @relation("SourceReturns")
  returnMovements Return[]       @relation("ReturnMovements")

  @@index([orgId, warehouseId])
  @@index([orgId, status, createdAt])
  @@map("movements")
}

// Movement Lines
model MovementLine {
  id         String   @id @default(cuid())
  movementId String
  productId  String
  locationId String?
  quantity   Int
  unitCost   Decimal? @db.Decimal(10, 2)
  currency   String
  orgId      String

  // Relations
  movement Movement  @relation(fields: [movementId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([movementId])
  @@index([movementId, orgId])
  @@index([productId, orgId])
  @@map("movement_lines")
}

// Transfers
model Transfer {
  id              String    @id @default(cuid())
  fromWarehouseId String
  toWarehouseId   String
  status          String    @default("DRAFT") // DRAFT, IN_TRANSIT, RECEIVED, REJECTED, CANCELED, PARTIAL
  note            String?
  initiatedAt     DateTime?
  receivedAt      DateTime?
  receivedBy      String?
  createdBy       String
  orgId           String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  fromWarehouse Warehouse      @relation("FromTransfers", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse      @relation("ToTransfers", fields: [toWarehouseId], references: [id])
  lines         TransferLine[]

  @@index([orgId, fromWarehouseId])
  @@index([orgId, toWarehouseId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("transfers")
}

// Transfer Lines
model TransferLine {
  id             String  @id @default(cuid())
  transferId     String
  productId      String
  quantity       Int
  fromLocationId String?
  toLocationId   String?
  orgId          String

  // Relations
  transfer Transfer @relation(fields: [transferId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([transferId])
  @@index([transferId, orgId])
  @@map("transfer_lines")
}

// Sales
model Sale {
  id                String    @id @default(cuid())
  saleNumber        String
  status            String    @default("DRAFT") // DRAFT, CONFIRMED, PICKING, SHIPPED, COMPLETED, CANCELLED, RETURNED
  warehouseId       String
  customerReference String?
  contactId         String?
  externalReference String?
  note              String?
  confirmedAt       DateTime?
  confirmedBy       String?
  cancelledAt       DateTime?
  cancelledBy       String?
  pickedAt          DateTime?
  pickedBy          String?
  shippedAt         DateTime?
  shippedBy         String?
  trackingNumber    String?
  shippingCarrier   String?
  shippingNotes     String?
  completedAt       DateTime?
  completedBy       String?
  returnedAt        DateTime?
  returnedBy        String?
  movementId        String?   @unique
  createdBy         String
  orgId             String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  contact   Contact?       @relation(fields: [contactId], references: [id])
  movement  Movement?      @relation(fields: [movementId], references: [id])
  lines     SaleLine[]
  returns   Return[]
  swaps     SaleLineSwap[]

  @@unique([saleNumber, orgId])
  @@index([status, orgId])
  @@index([orgId, warehouseId])
  @@index([orgId, contactId])
  @@index([orgId, status, createdAt])
  @@index([orgId, createdAt])
  @@map("sales")
}

// Sale Lines
model SaleLine {
  id         String   @id @default(cuid())
  saleId     String
  productId  String
  locationId String? // Optional - for MVP warehouse is the location
  quantity   Decimal  @db.Decimal(10, 6)
  salePrice  Decimal  @db.Decimal(10, 2)
  currency   String
  extra      Json?
  orgId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([saleId])
  @@index([productId, orgId])
  @@index([locationId])
  @@map("sale_lines")
}

// Returns
model Return {
  id               String    @id @default(cuid())
  returnNumber     String
  status           String    @default("DRAFT") // DRAFT, CONFIRMED, CANCELLED
  type             String // RETURN_CUSTOMER, RETURN_SUPPLIER
  reason           String?
  warehouseId      String
  saleId           String? // For customer returns
  sourceMovementId String? // For supplier returns (purchase movement)
  returnMovementId String?   @unique // Generated movement (IN for customer, OUT for supplier)
  note             String?
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  createdBy        String
  orgId            String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id])
  sale           Sale?        @relation(fields: [saleId], references: [id])
  sourceMovement Movement?    @relation("SourceReturns", fields: [sourceMovementId], references: [id])
  returnMovement Movement?    @relation("ReturnMovements", fields: [returnMovementId], references: [id])
  lines          ReturnLine[]

  @@unique([returnNumber, orgId])
  @@index([status, orgId])
  @@index([type, orgId])
  @@index([saleId, orgId])
  @@index([sourceMovementId, orgId])
  @@index([orgId, warehouseId])
  @@index([orgId, status, createdAt])
  @@index([orgId, createdAt])
  @@map("returns")
}

// Return Lines
model ReturnLine {
  id                String   @id @default(cuid())
  returnId          String
  productId         String
  locationId        String? // Optional - for MVP warehouse is the location
  quantity          Decimal  @db.Decimal(10, 6)
  originalSalePrice Decimal? @db.Decimal(10, 2) // For customer returns
  originalUnitCost  Decimal? @db.Decimal(10, 2) // For supplier returns
  currency          String
  extra             Json?
  orgId             String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  return   Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([returnId])
  @@index([productId, orgId])
  @@index([locationId])
  @@map("return_lines")
}

// Categories
model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id])
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  products     Product[]    @relation("ProductCategories")

  @@unique([name, orgId])
  @@index([orgId])
  @@index([orgId, parentId])
  @@map("categories")
}

// Audit Logs
model AuditLog {
  id             String   @id @default(cuid())
  orgId          String? // Nullable for system-level audits
  entityType     String // User, Product, Warehouse, etc.
  entityId       String? // Nullable for system-level actions
  action         String // CREATE, UPDATE, DELETE, ASSIGN_ROLE, etc.
  performedBy    String? // User ID, nullable for system actions
  metadata       Json? // Flexible JSON for additional data
  ipAddress      String?
  userAgent      String?
  httpMethod     String? // GET, POST, PUT, DELETE, etc.
  httpUrl        String?
  httpStatusCode Int?
  duration       Int? // Request duration in ms
  createdAt      DateTime @default(now())

  // Indexes for performance
  @@index([orgId, createdAt])
  @@index([orgId, entityType, createdAt])
  @@index([orgId, entityId, entityType])
  @@index([orgId, performedBy, createdAt])
  @@index([orgId, action, createdAt])
  @@index([createdAt]) // For date range queries
  @@map("audit_logs")
}

// Report Templates (reusable report configurations)
model ReportTemplate {
  id                String    @id @default(cuid())
  orgId             String
  name              String
  description       String?
  type              String // ReportType value (AVAILABLE_INVENTORY, SALES, etc.)
  defaultParameters Json // ReportParameters as JSON
  isActive          Boolean   @default(true)
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  reports Report[]

  @@unique([orgId, name])
  @@index([orgId, type])
  @@index([orgId, isActive])
  @@map("report_templates")
}

// Reports (metadata for audit/logging of report executions)
model Report {
  id           String    @id @default(cuid())
  orgId        String
  type         String // ReportType value (AVAILABLE_INVENTORY, SALES, etc.)
  status       String    @default("PENDING") // PENDING, GENERATING, COMPLETED, FAILED, EXPORTED
  parameters   Json // ReportParameters as JSON
  templateId   String?
  generatedBy  String
  generatedAt  DateTime?
  format       String? // ReportFormat value (PDF, EXCEL, CSV) - only if exported
  exportedAt   DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // Relations
  template ReportTemplate? @relation(fields: [templateId], references: [id])

  @@index([orgId, type])
  @@index([orgId, status])
  @@index([orgId, generatedAt])
  @@index([orgId, generatedBy])
  @@map("reports")
}

// Import Batches (Import processing batches)
model ImportBatch {
  id            String    @id @default(cuid())
  orgId         String
  type          String // PRODUCTS, MOVEMENTS, WAREHOUSES, STOCK, TRANSFERS
  status        String    @default("PENDING") // PENDING, VALIDATING, VALIDATED, PROCESSING, COMPLETED, FAILED
  fileName      String
  totalRows     Int       @default(0)
  processedRows Int       @default(0)
  validRows     Int       @default(0)
  invalidRows   Int       @default(0)
  startedAt     DateTime?
  validatedAt   DateTime?
  completedAt   DateTime?
  errorMessage  String?
  note          String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  rows ImportRow[]

  @@index([orgId, type])
  @@index([orgId, status])
  @@index([orgId, createdBy])
  @@index([orgId, createdAt])
  @@map("import_batches")
}

// Import Rows (Individual rows in an import batch)
model ImportRow {
  id               String   @id @default(cuid())
  orgId            String
  importBatchId    String
  rowNumber        Int
  data             Json // Raw row data
  isValid          Boolean  @default(true)
  validationErrors Json? // Array of validation errors
  warnings         Json? // Array of warnings
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([importBatchId, rowNumber])
  @@index([importBatchId])
  @@index([orgId, isValid])
  @@map("import_rows")
}

// Document Number Sequences (for atomic document number generation: SALE, RETURN, etc.)
model DocumentNumberSequence {
  id           String   @id @default(cuid())
  orgId        String
  type         String   // SALE, RETURN, etc.
  year         Int
  lastSequence Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, type, year])
  @@map("document_number_sequences")
}

// Processed Events (for event handler idempotency - prevents duplicate processing)
model ProcessedEvent {
  id          String   @id @default(cuid())
  eventType   String   // Event class name (e.g., MovementPostedEvent)
  eventId     String   // Unique event identifier (e.g., movementId, saleId)
  orgId       String
  processedAt DateTime @default(now())

  @@unique([eventType, eventId, orgId])
  @@index([orgId, eventType])
  @@index([processedAt])
  @@map("processed_events")
}

// Sale Line Swaps (product swap in confirmed/picking sales)
model SaleLineSwap {
  id                   String   @id @default(cuid())
  saleId               String
  originalLineId       String
  newLineId            String?
  originalProductId    String
  originalQuantity     Decimal  @db.Decimal(10, 6)
  originalSalePrice    Decimal  @db.Decimal(10, 2)
  originalCurrency     String
  replacementProductId String
  replacementQuantity  Decimal  @db.Decimal(10, 6)
  replacementSalePrice Decimal  @db.Decimal(10, 2)
  replacementCurrency  String
  originalWarehouseId  String
  sourceWarehouseId    String
  isCrossWarehouse     Boolean  @default(false)
  returnMovementId     String?
  deductMovementId     String?
  pricingStrategy      String // KEEP_ORIGINAL | NEW_PRICE
  reason               String?
  performedBy          String
  orgId                String
  createdAt            DateTime @default(now())

  // Relations
  sale               Sale    @relation(fields: [saleId], references: [id])
  originalProduct    Product @relation("SwapOriginalProduct", fields: [originalProductId], references: [id])
  replacementProduct Product @relation("SwapReplacementProduct", fields: [replacementProductId], references: [id])

  @@index([saleId, orgId])
  @@index([orgId, createdAt])
  @@map("sale_line_swaps")
}

// Contacts (Customers/Suppliers)
model Contact {
  id             String    @id @default(cuid())
  name           String
  identification String
  type           String    @default("CUSTOMER") // CUSTOMER, SUPPLIER
  email          String?
  phone          String?
  address        String?
  notes          String?
  isActive       Boolean   @default(true)
  orgId          String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  sales        Sale[]
  movements    Movement[]
  integrations IntegrationConnection[]

  @@unique([identification, orgId])
  @@index([orgId])
  @@index([orgId, type])
  @@index([orgId, isActive])
  @@index([email, orgId])
  @@map("contacts")
}

// Companies (Business Lines within an organization)
model Company {
  id          String   @id @default(cuid())
  name        String
  code        String
  description String?
  isActive    Boolean  @default(true)
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id])
  products     Product[]
  integrations IntegrationConnection[]

  @@unique([code, orgId])
  @@unique([name, orgId])
  @@index([orgId])
  @@index([orgId, isActive])
  @@map("companies")
}

// Alert Configuration (per organization - configures stock alert cron)
model AlertConfiguration {
  id                  String   @id @default(cuid())
  orgId               String   @unique
  cronFrequency       String   @default("EVERY_HOUR") // EVERY_HOUR, EVERY_6_HOURS, EVERY_12_HOURS, EVERY_DAY
  notifyLowStock      Boolean  @default(true)
  notifyCriticalStock Boolean  @default(true)
  notifyOutOfStock    Boolean  @default(true)
  recipientEmails     String   @default("")
  isEnabled           Boolean  @default(true)
  lastRunAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id])

  @@map("alert_configurations")
}

// Integration Connections (e-commerce integrations like VTEX)
model IntegrationConnection {
  id                 String    @id @default(cuid())
  provider           String
  accountName        String
  storeName          String
  status             String    @default("DISCONNECTED")
  syncStrategy       String    @default("BOTH")
  syncDirection      String    @default("BIDIRECTIONAL")
  encryptedAppKey    String
  encryptedAppToken  String
  webhookSecret      String
  defaultWarehouseId String
  defaultContactId   String?
  connectedAt        DateTime?
  lastSyncAt         DateTime?
  lastSyncError      String?
  companyId               String?
  encryptedAccessToken    String?
  encryptedRefreshToken   String?
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  meliUserId              String?
  tokenStatus             String?
  orgId                   String
  createdBy               String
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  warehouse      Warehouse @relation(fields: [defaultWarehouseId], references: [id])
  defaultContact Contact?  @relation(fields: [defaultContactId], references: [id])
  company        Company?  @relation(fields: [companyId], references: [id])
  syncLogs       IntegrationSyncLog[]
  skuMappings    IntegrationSkuMapping[]

  @@unique([provider, accountName, orgId])
  @@index([orgId, provider])
  @@index([status])
  @@index([meliUserId])
  @@map("integration_connections")
}

// Integration Sync Logs (tracks each synced order)
model IntegrationSyncLog {
  id              String   @id @default(cuid())
  connectionId    String
  externalOrderId String
  externalOrderStatus String?
  action          String
  saleId          String?
  saleNumber      String?
  contactId       String?
  contactName     String?
  errorMessage    String?
  rawPayload      Json?
  orgId           String
  processedAt     DateTime @default(now())

  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalOrderId])
  @@index([connectionId])
  @@index([orgId, externalOrderId])
  @@map("integration_sync_logs")
}

// Integration SKU Mappings (maps external SKUs to internal products)
model IntegrationSkuMapping {
  id              String   @id @default(cuid())
  connectionId    String
  externalSku     String
  productId       String
  orgId           String
  createdAt       DateTime @default(now())

  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  product    Product               @relation(fields: [productId], references: [id])

  @@unique([connectionId, externalSku])
  @@index([connectionId])
  @@map("integration_sku_mappings")
}
